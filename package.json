{
  "name": "create-nestjs-ts-app",
  "private": true,
  "version": "0.0.1",
  "description": "NestJS + TypeScript API boilerplate (template + create-nestjs-ts-app CLI)",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "process": "node dist/process scanner",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --detectOpenHandles",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:up": "mikro-orm migration:up",
    "db:migrate": "mikro-orm schema:drop && mikro-orm migration:create",
    "db:fresh": "mikro-orm migration:fresh",
    "db:seed": "mikro-orm migration:fresh --seed",
    "pm2:delete": "pm2 delete all || true",
    "pm2:dev": "yarn build && yarn pm2:delete && pm2 start ecosystem.config.js --env development",
    "pm2:prod": "yarn build && yarn pm2:delete && pm2 start ecosystem.config.js --env production"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/static": "^9.3.0",
    "@mikro-orm/cli": "^6.6.15",
    "@mikro-orm/core": "^6.6.15",
    "@mikro-orm/migrations": "^6.6.15",
    "@mikro-orm/nestjs": "^6.1.2",
    "@mikro-orm/postgresql": "^6.6.15",
    "@mikro-orm/seeder": "^6.6.15",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/terminus": "^11.1.1",
    "@types/inquirer": "^8.1.3",
    "bullmq": "^5.45.2",
    "cache-manager": "^6.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "fastify": "^5.10.0",
    "keyv": "^5.6.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "nest-commander": "^3.17.0",
    "nest-winston": "^1.10.2",
    "pm2": "^7.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uid": "^2.0.2",
    "uuid": "^11.1.0",
    "webpack": "^5.108.4",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.28",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/winston": "^2.4.4",
    "chokidar": "^5.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "glob": "^11.1.0",
    "js-yaml": "^4.2.0",
    "ajv": "^8.18.0",
    "brace-expansion": "^2.0.2",
    "file-type": "^21.3.2",
    "lodash": "^4.18.1"
  }
}
